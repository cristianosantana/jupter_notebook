# =============================================================================
# Variáveis de ambiente — copie para .env e preencha. Não commite segredos.
# Mapeamento Pydantic: app/config.py (maiúsculas + underscore = nome da env var).
# Trace: com AGENT_TRACE_ENABLED=true, cada POST /api/chat grava no fim do run o evento
# JSONL openai.chat_completions.summary (contagens por llm_phase, duração total em ms).
# =============================================================================

#  1 OPENAI_API_KEY — Bearer token OpenAI; usado por OpenAIProvider, arranque MCP (sampling) e orquestrador.
OPENAI_API_KEY=

#  2 OPENAI_MODEL — Modelo por omissão; sobrescrito por ORCHESTRATOR_MODEL_* quando esse valor não está vazio (resolve_orchestrator_model_for_agent).
OPENAI_MODEL=gpt-4o-mini

#  3 ORCHESTRATOR_MAX_TOOL_ROUNDS — Tecto de voltas do loop LLM↔tools no maestro e no especialista (_run_maestro_routing_phase / _run_specialist_loop); exceder gera erro.
ORCHESTRATOR_MAX_TOOL_ROUNDS=24

#  4 ORCHESTRATOR_MAX_HISTORY_MESSAGES — Após podagem por idade e orçamento, o histórico não excede este número de mensagens (orchestrator.py _cap_messages).
ORCHESTRATOR_MAX_HISTORY_MESSAGES=20

#  5 ORCHESTRATOR_MAX_MESSAGE_AGE_SECONDS — Mensagens com timestamp implícito mais antigo que agora−N segundos são removidas antes de enviar ao modelo.
ORCHESTRATOR_MAX_MESSAGE_AGE_SECONDS=7200

#  6 ORCHESTRATOR_TOOL_RESULT_PREVIEW_MAX — Caracteres da prévia do resultado da tool em tools_used (resposta HTTP / observador), não o texto completo enviado ao LLM.
ORCHESTRATOR_TOOL_RESULT_PREVIEW_MAX=500

#  7 ORCHESTRATOR_CONTEXT_BUDGET_SAFETY_MARGIN — Caracteres reservados ao lado da estimativa de contexto ao calcular quanto histórico cabe (_estimate_context_budget).
ORCHESTRATOR_CONTEXT_BUDGET_SAFETY_MARGIN=768

#  8 ORCHESTRATOR_CHARS_PER_TOKEN_ESTIMATE — Divide caracteres para estimar “tokens” na podagem de contexto (heurística, não é tokenizer oficial).
ORCHESTRATOR_CHARS_PER_TOKEN_ESTIMATE=3

#  9 ORCHESTRATOR_AGENT_TYPES — Agentes permitidos em handoff e validação de sessão PostgreSQL (orchestrator_agent_types_frozenset); vírgula, sem espaços nos nomes.
ORCHESTRATOR_AGENT_TYPES=maestro,analise_os,clusterizacao,visualizador,agregador,projecoes,verificador,compositor_layout

# 10 ORCHESTRATOR_GLOSSARY_CACHE_ANONYMOUS_UUID — UUID válido usado como chave do LRU do glossário quando não há session_id (sessão só em memória).
ORCHESTRATOR_GLOSSARY_CACHE_ANONYMOUS_UUID=00000000-0000-0000-0000-000000000001

# 11 ORCHESTRATOR_MODEL_MAESTRO — Override do modelo só na fase de roteamento / maestro (llm_phase orchestrator:maestro).
ORCHESTRATOR_MODEL_MAESTRO=

# 12 ORCHESTRATOR_MODEL_ANALISE_OS — Override para o agente analise_os (queries MCP, OS).
ORCHESTRATOR_MODEL_ANALISE_OS=

# 13 ORCHESTRATOR_MODEL_CLUSTERIZACAO — Override para clusterização.
ORCHESTRATOR_MODEL_CLUSTERIZACAO=

# 14 ORCHESTRATOR_MODEL_VISUALIZADOR — Override para o agente visualizador.
ORCHESTRATOR_MODEL_VISUALIZADOR=

# 15 ORCHESTRATOR_MODEL_AGREGADOR — Override para agregador.
ORCHESTRATOR_MODEL_AGREGADOR=

# 16 ORCHESTRATOR_MODEL_PROJECOES — Override para projeções.
ORCHESTRATOR_MODEL_PROJECOES=

# 17 ORCHESTRATOR_MODEL_VERIFICADOR — Override para o skill verificador na pipeline F3 (além do agente homónimo se usado).
ORCHESTRATOR_MODEL_VERIFICADOR=

# 18 ORCHESTRATOR_MODEL_COMPOSITOR_LAYOUT — Override para o compositor JSON de layout na pipeline F3.
ORCHESTRATOR_MODEL_COMPOSITOR_LAYOUT=

# 19 ENTITY_GLOSSARY_MCP_TOOL — Nome da tool no servidor MCP cujo resultado markdown é fundido no system (deve coincidir com o registo no MCP).
ENTITY_GLOSSARY_MCP_TOOL=get_entity_glossary_markdown

# 20 MYSQL_HOST — Host MySQL; copiado para os.environ no arranque (sync_mysql_env_from_settings) para o subprocesso MCP e glossário.
MYSQL_HOST=localhost

# 21 MYSQL_PORT — Porta TCP do MySQL.
MYSQL_PORT=3306

# 22 MYSQL_USER — Utilizador da ligação MySQL.
MYSQL_USER=

# 23 MYSQL_PASSWORD — Senha MySQL (analytics MCP + queries do glossário na API).
MYSQL_PASSWORD=

# 24 MYSQL_DATABASE — Nome da base de dados de negócio.
MYSQL_DATABASE=

# 25 POSTGRES_HOST — Se vazio (junto com user/database necessários), postgres_enabled=false: sem persistência de sessões/transcript.
POSTGRES_HOST=

# 26 POSTGRES_PORT — Porta do PostgreSQL.
POSTGRES_PORT=5432

# 27 POSTGRES_USER — Utilizador da base de sessões.
POSTGRES_USER=

# 28 POSTGRES_PASSWORD — Senha PostgreSQL.
POSTGRES_PASSWORD=

# 29 POSTGRES_DATABASE — Nome da base onde vivem sessions/messages/metadata (ex.: maestro_sessions).
POSTGRES_DATABASE=maestro_sessions

# 30 POSTGRES_AUTO_MIGRATE — Se true, SessionStore corre migrações SQL ao arranque quando PostgreSQL está activo.
POSTGRES_AUTO_MIGRATE=true

# 31 ENTITY_GLOSSARY_SQL_FUN_EXTRA — Sufixo SQL injectado na query de funcionários do glossário (começar por espaço + AND …); ver entity_glossary.py.
ENTITY_GLOSSARY_SQL_FUN_EXTRA=

# 32 ENTITY_GLOSSARY_SQL_CONCESSIONARIAS_EXTRA — Idem para o ramo concessionárias no markdown do glossário.
ENTITY_GLOSSARY_SQL_CONCESSIONARIAS_EXTRA=

# 33 ENTITY_GLOSSARY_SQL_SERVICOS_EXTRA — Idem para o ramo serviços no glossário.
ENTITY_GLOSSARY_SQL_SERVICOS_EXTRA=

# 34 ENTITY_GLOSSARY_SESSION_CACHE_ENABLED — Se false, desliga o LRU em RAM do markdown do glossário por session_id (sempre refresh via MCP/MySQL quando aplicável).
ENTITY_GLOSSARY_SESSION_CACHE_ENABLED=true

# 35 ENTITY_GLOSSARY_SESSION_CACHE_MAX — Máximo de entradas no LRU do glossário por processo (orchestrator).
ENTITY_GLOSSARY_SESSION_CACHE_MAX=256

# 36 MEMORY_PROMPTS_ENABLED — Se false, maybe_update_* e extração de memória são no-op (memory_prompts.py).
MEMORY_PROMPTS_ENABLED=false

# 37 MEMORY_CONVERSATION_SUMMARY_ENABLED — Activa resumo rolling do transcript em metadata.conversation_summary (prompt conversation-summary.md).
MEMORY_CONVERSATION_SUMMARY_ENABLED=false

# 38 MEMORY_SESSION_NOTES_ENABLED — Activa notas estruturadas JSON em metadata.session_notes (session-notes.md).
MEMORY_SESSION_NOTES_ENABLED=false

# 39 MEMORY_EXTRACTION_ENABLED — Activa extração incremental para metadata.extracted_memory (memory-extraction.md).
MEMORY_EXTRACTION_ENABLED=false

# 40 MEMORY_CONSOLIDATION_ENABLED — Flag em Settings; reservada para consolidação de memória (sem uso activo noutros módulos no estado actual do repo).
MEMORY_CONSOLIDATION_ENABLED=false

# 41 MCP_CACHE_ENTRY_MAX_CHARS — Teto de caracteres guardados por resultado de tool em sessions.metadata.mcp_tool_cache.entries (append_cache_entry).
MCP_CACHE_ENTRY_MAX_CHARS=200000

# 42 MCP_CACHE_DIGEST_MAX_CHARS — Tamanho máximo do bloco markdown “digest” de cache MCP injectado no system (build_mcp_cache_digest_section).
MCP_CACHE_DIGEST_MAX_CHARS=12000

# 43 MCP_CACHE_DIGEST_MAX_ENTRIES — Quantas entradas recentes do cache entram no digest (mais recentes primeiro).
MCP_CACHE_DIGEST_MAX_ENTRIES=24

# 44 MCP_CACHE_DIGEST_MAX_CHARS_PER_ENTRY — Truncagem por entrada antes de compor o digest.
MCP_CACHE_DIGEST_MAX_CHARS_PER_ENTRY=1800

# 45 MCP_CACHE_DIGEST_LLM_ENABLED — Se true, pode chamar um LLM para condensar o digest base (_digest_for_system_async / mcp_digest_editor.md).
MCP_CACHE_DIGEST_LLM_ENABLED=false

# 46 MCP_CACHE_DIGEST_LLM_TRIGGER — when_base_too_long: só corre o editor LLM se o digest base tiver ≥ MCP_CACHE_DIGEST_LLM_MIN_CHARS_TO_RUN caracteres.
MCP_CACHE_DIGEST_LLM_TRIGGER=when_base_too_long

# 47 MCP_CACHE_DIGEST_LLM_MODEL — Modelo OpenAI para o editor do digest; vazio = mesmo fluxo que effective_model_for_agent (override None → openai_model).
MCP_CACHE_DIGEST_LLM_MODEL=

# 48 MCP_CACHE_DIGEST_LLM_TIMEOUT_SECONDS — asyncio.wait_for à volta da chamada ao modelo do digest (evita pendura indefinida).
MCP_CACHE_DIGEST_LLM_TIMEOUT_SECONDS=45

# 49 MCP_CACHE_DIGEST_LLM_MAX_OUTPUT_CHARS — Truncagem da saída do editor LLM antes de gravar em mcp_digest_llm_cache.
MCP_CACHE_DIGEST_LLM_MAX_OUTPUT_CHARS=4000

# 50 MCP_CACHE_DIGEST_LLM_MIN_CHARS_TO_RUN — Com trigger when_base_too_long, digest base mais curto que isto não dispara o LLM.
MCP_CACHE_DIGEST_LLM_MIN_CHARS_TO_RUN=2500

# 51 MCP_CACHE_DIGEST_LLM_REUSE_HASH — Se true, reutiliza digest LLM em cache quando o fingerprint das entradas MCP não mudou.
MCP_CACHE_DIGEST_LLM_REUSE_HASH=true

# 52 PIPELINE_VERIFIER_ENABLED — Após o especialista, chama o verificador (skill verificador) contra o digest; grava verification_status em metadata.
PIPELINE_VERIFIER_ENABLED=false

# 53 PIPELINE_COMPOSITOR_ENABLED — Se activo e não bloqueado por REPROVADO, gera layout_blocks JSON via compositor_layout.
PIPELINE_COMPOSITOR_ENABLED=false

# --- Pipeline avaliador crítico + formatador UI (pós-especialista) ---
# Ciclo APROVAR/DEVOLVER com transcript preservado.
PIPELINE_CRITICAL_EVALUATOR_ENABLED=false

# Máximo de devoluções do avaliador ao especialista por pedido.
ORCHESTRATOR_MAX_CRITIQUE_ROUNDS=3

# Override OpenAI para avaliador_critico.
ORCHESTRATOR_MODEL_AVALIADOR_CRITICO=gpt-5-mini

# Após aprovação, gera content_blocks JSON na mensagem final (campo Settings: pipeline_formatador_ui_enabled).
PIPELINE_FORMATADOR_UI_ENABLED=false

# Override para formatador_ui.
ORCHESTRATOR_MODEL_FORMATADOR_UI=gpt-5-mini

# Evita compositor duplicado se formatador válido.
PIPELINE_SKIP_COMPOSITOR_WHEN_FORMATADOR_SUCCEEDS=false

# --- SerpApi (Google Search via MCP) ---
# Copiada para o subprocesso MCP no arranque (sync_mysql_env_from_settings).
SERPAPI_API_KEY=

# false omite o registo da tool google_search_serpapi no servidor MCP.
SERPAPI_ENABLED=false

# --- Allowlist opcional de tools MCP por especialista (JSON numa linha) ---
# JSON {"analise_os":["run_analytics_query",...]} — allowlist de nomes de tools MCP por agente. 
# Vazio = sem filtro (todas as tools do servidor para cada especialista).
ORCHESTRATOR_TOOL_ALLOWLIST_JSON={
    "analise_os":[
        "list_analytics_queries",
        "run_analytics_query",
        "google_search_serpapi"
    ]
}

# 54 VERIFICATION_DEPTH — Passado no user message ao verificador (smoke ou outros valores suportados pelo prompt; texto livre consumido pelo skill).
VERIFICATION_DEPTH=smoke

# 55 OBSERVER_AGENT_ENABLED — Se true, no fim do run gera narrativa técnica do turno (observer.md) e acrescenta a observer_log / metadata.
OBSERVER_AGENT_ENABLED=false

# 56 OBSERVER_AGENT_MODEL — Modelo para a narrativa do observador; vazio usa o mesmo critério de override (openai_model).
OBSERVER_AGENT_MODEL=

# 57 OBSERVER_LOG_MAX_ENTRIES — Máximo de eventos estruturados mantidos em observer_log.entries antes de podar.
OBSERVER_LOG_MAX_ENTRIES=500

# 58 OBSERVER_NARRATIVES_MAX — Quantas narrativas completas (texto do observador) guardar em metadata.
OBSERVER_NARRATIVES_MAX=50

# 59 OBSERVER_NARRATIVE_MAX_CHARS — Truncagem de cada narrativa persistida.
OBSERVER_NARRATIVE_MAX_CHARS=8000

# 60 AGENT_TRACE_ENABLED — false desliga a pasta de trace (resolve_agent_trace_dir retorna None).
AGENT_TRACE_ENABLED=true

# 61 AGENT_TRACE_DIR — Caminho absoluto ou relativo para {run_id}_app.jsonl / _server.jsonl; vazio → projecto/logs/agent_trace.
AGENT_TRACE_DIR=

# 62 AGENT_TRACE_MAX_FIELD_CHARS — Truncagem por campo JSON no trace; ≤0 desactiva truncagem (ficheiros grandes; cuidado com PII).
AGENT_TRACE_MAX_FIELD_CHARS=600000

# -----------------------------------------------------------------------------
# Opcional — definidas em app/config.py mas omitidas acima (omissões seguras).
# -----------------------------------------------------------------------------

# 63 CORS_ORIGINS — Origens permitidas pelo FastAPI CORSMiddleware, separadas por vírgula (ex.: http://localhost:5173).
CORS_ORIGINS=http://localhost:5173

# 64 ENTITY_GLOSSARY_ENABLED — false desliga a injecção do glossário no system (orquestrador).
ENTITY_GLOSSARY_ENABLED=true

# 65 ENTITY_GLOSSARY_MAX_CHARS — Truncagem do markdown do glossário antes de fundir no system.
ENTITY_GLOSSARY_MAX_CHARS=24000

# 66 ENTITY_GLOSSARY_ON_HANDOFF — Se true, o orquestrador pode refrescar o glossário após handoff do Maestro para o especialista (evita glossário vazio no primeiro turno).
ENTITY_GLOSSARY_ON_HANDOFF=true

# 67 ENTITY_GLOSSARY_INCLUDE_DEMAIS_REGISTOS — Inclui no glossário pessoas via JOIN funcionario_cargos / cargos (ver entity_glossary.py).
ENTITY_GLOSSARY_INCLUDE_DEMAIS_REGISTOS=true

# 68 POSTGRES_MAINTENANCE_DATABASE — Base onde ligar para CREATE DATABASE quando POSTGRES_DATABASE ainda não existe (migrações bootstrap).
POSTGRES_MAINTENANCE_DATABASE=postgres

# 69 TOOL_MESSAGE_CONTENT_MAX_CHARS — Teto ao serializar conteúdo de mensagens role=tool para o LLM (_execute_single_tool_call).
TOOL_MESSAGE_CONTENT_MAX_CHARS=600000
