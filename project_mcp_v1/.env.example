OPENAI_API_KEY=
# Modelo por omissão quando ORCHESTRATOR_MODEL_* está vazio
OPENAI_MODEL=gpt-4o-mini

# Orquestrador — limites e podagem (valores por omissão = os números abaixo)
ORCHESTRATOR_MAX_TOOL_ROUNDS=24
ORCHESTRATOR_MAX_HISTORY_MESSAGES=20
ORCHESTRATOR_MAX_MESSAGE_AGE_SECONDS=7200
ORCHESTRATOR_TOOL_RESULT_PREVIEW_MAX=500
ORCHESTRATOR_CONTEXT_BUDGET_SAFETY_MARGIN=768
ORCHESTRATOR_CHARS_PER_TOKEN_ESTIMATE=3
# Lista de agentes válidos (vírgulas); alinhar com skills *.md
ORCHESTRATOR_AGENT_TYPES=maestro,analise_os,clusterizacao,visualizador,agregador,projecoes,verificador,compositor_layout
# Chave de cache do glossário sem session_id PostgreSQL
ORCHESTRATOR_GLOSSARY_CACHE_ANONYMOUS_UUID=00000000-0000-0000-0000-000000000001
# Modelo OpenAI por agente (vazio = usar OPENAI_MODEL)
ORCHESTRATOR_MODEL_MAESTRO=
ORCHESTRATOR_MODEL_ANALISE_OS=
ORCHESTRATOR_MODEL_CLUSTERIZACAO=
ORCHESTRATOR_MODEL_VISUALIZADOR=
ORCHESTRATOR_MODEL_AGREGADOR=
ORCHESTRATOR_MODEL_PROJECOES=
ORCHESTRATOR_MODEL_VERIFICADOR=
ORCHESTRATOR_MODEL_COMPOSITOR_LAYOUT=

# Nome da ferramenta MCP do glossário (servidor MCP)
ENTITY_GLOSSARY_MCP_TOOL=get_entity_glossary_markdown

# Trace JSONL (API + cliente MCP; servidor MCP usa AGENT_TRACE_DIR / AGENT_TRACE_MAX_FIELD_CHARS no env)
# AGENT_TRACE_DIR vazio = pasta por omissão em logs/agent_trace (não versionar essa pasta).
# AGENT_TRACE_MAX_FIELD_CHARS: positivo = teto por campo; 0 ou negativo = sem truncagem (ficheiros enormes; PII).
AGENT_TRACE_ENABLED=true
AGENT_TRACE_DIR=
AGENT_TRACE_MAX_FIELD_CHARS=600000

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# PostgreSQL — sessões e utilizadores (opcional; vazio desactiva persistência)
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=maestro_sessions
POSTGRES_AUTO_MIGRATE=true

# Memory prompts (opcional; master desliga tudo)
MEMORY_PROMPTS_ENABLED=false
MEMORY_CONVERSATION_SUMMARY_ENABLED=false
MEMORY_SESSION_NOTES_ENABLED=false
MEMORY_EXTRACTION_ENABLED=false
MEMORY_CONSOLIDATION_ENABLED=false

# Cache MCP + digest (digest LLM opcional)
MCP_CACHE_ENTRY_MAX_CHARS=200000
MCP_CACHE_DIGEST_MAX_CHARS=12000
MCP_CACHE_DIGEST_MAX_ENTRIES=24
MCP_CACHE_DIGEST_MAX_CHARS_PER_ENTRY=1800
MCP_CACHE_DIGEST_LLM_ENABLED=false
MCP_CACHE_DIGEST_LLM_TRIGGER=when_base_too_long
MCP_CACHE_DIGEST_LLM_MODEL=
MCP_CACHE_DIGEST_LLM_TIMEOUT_SECONDS=45
MCP_CACHE_DIGEST_LLM_MAX_OUTPUT_CHARS=4000
MCP_CACHE_DIGEST_LLM_MIN_CHARS_TO_RUN=2500
MCP_CACHE_DIGEST_LLM_REUSE_HASH=true

# Pipeline Frente 3
PIPELINE_VERIFIER_ENABLED=false
PIPELINE_COMPOSITOR_ENABLED=false
VERIFICATION_DEPTH=smoke

# Observador (log em sessions.metadata)
OBSERVER_AGENT_ENABLED=false
OBSERVER_AGENT_MODEL=
OBSERVER_LOG_MAX_ENTRIES=500
OBSERVER_NARRATIVES_MAX=50
OBSERVER_NARRATIVE_MAX_CHARS=8000
