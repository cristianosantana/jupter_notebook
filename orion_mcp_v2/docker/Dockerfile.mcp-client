FROM python:3.12-slim-bookworm

WORKDIR /app
ENV PYTHONUNBUFFERED=1

COPY pyproject.toml README.md ./
COPY src ./src
COPY scripts/mcp_remote_client.py ./scripts/
RUN pip install --no-cache-dir pip setuptools wheel \
    && pip install --no-cache-dir .

# Smoke: listar tools na URL configurada (requer MCP_SERVER_URL)
CMD ["python", "scripts/mcp_remote_client.py"]
