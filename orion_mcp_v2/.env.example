APP_NAME=orion_mcp_v2
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# --- Dev local (Python na máquina): localhost em baixo funciona.
# --- Docker Compose com rede externa docker-env_cs_backend (stack cs_*):
#     use os nomes dos contentores como host — cs_postgres, cs_redis, cs_mysql —
#     para DNS resolver dentro da rede partilhada (nunca localhost no container).

ORION_V2_DATABASE_URL=postgresql://postgres:secret@cs_postgres:5432/dev
# Exemplo Docker + rede cs_*: postgresql://USER:PASS@cs_postgres:5432/NOME_BD
ORION_V2_DB_REQUIRED=false

ORION_V2_MYSQL_URL=mysql://analytics:secret456@cs_mysql:3306/dealership
# Exemplo Docker + rede cs_*: mysql://USER:PASS@cs_mysql:3306/dealership

ORION_V2_REDIS_URL=redis://cs_redis:6379/0
# Exemplo Docker + rede cs_*: redis://cs_redis:6379/0

ORION_V2_OPENAI_API_KEY=
ORION_V2_OPENAI_MODEL=gpt-5-mini

ORION_V2_CELERY_BROKER_URL=redis://cs_redis:6379/1
ORION_V2_CELERY_RESULT_BACKEND=redis://cs_redis:6379/2
# Em Docker com cs_redis: redis://cs_redis:6379/1 e redis://cs_redis:6379/2

ORION_V2_CONSOLIDATION_HOUR=3
ORION_V2_CONSOLIDATION_MINUTE=0
ORION_V2_MEMORY_CURTA_TTL_SECONDS=604800
ORION_V2_SESSION_RETENTION_DAYS=30

ORION_V2_RATE_LIMIT_PER_MINUTE=60

# --- Servidor MCP isolado (Serviço B / FastMCP) ---
ORION_V2_MCP_SRV_HOST=0.0.0.0
ORION_V2_MCP_SRV_PORT=8765
ORION_V2_MCP_SRV_TRANSPORT=sse
# Preferência: URL só para o MCP; senão usa ORION_V2_MYSQL_URL
# Docker + cs_*: mysql://USER:PASS@cs_mysql:3306/dealership
ORION_V2_MCP_SRV_MYSQL_URL=

# --- Cliente MCP remoto (Serviço C / CLI ou terceiro container) ---
MCP_SERVER_URL=http://127.0.0.1:8765/sse

# --- Observabilidade opcional ---
ORION_V2_OTEL_ENABLED=false

# --- Dump I/O LLM (opcional): um JSON por chamada com mensagens + response_raw da API ---
# Em Docker: monte um volume no directório (ex.: - ./llm_dumps:/tmp/orion_mcp_v2_llm_io) para ver ficheiros no host.
ORION_V2_LLM_IO_DUMP_ENABLED=false
ORION_V2_LLM_IO_DUMP_DIR=/tmp/orion_mcp_v2_llm_io

# NDJSON do orquestrador (contexto antes do LLM). Activável só aqui ou junto com LLM_IO_DUMP_ENABLED.
# Log por defeito dentro do container: /tmp/orion_mcp_v2_agent_debug.ndjson — monte volume se quiser no host.
ORION_V2_AGENT_DEBUG_NDJSON_ENABLED=false
# ORION_V2_AGENT_DEBUG_LOG_PATH=/tmp/orion_mcp_v2_agent_debug.ndjson

# --- Orçamento LLM (opcional; ver Settings) ---
# ORION_V2_LLM_CONTEXT_MAX_CHARS=
# ORION_V2_LLM_PROMPT_TOKEN_BUDGET=
# Lookups ID→nome (anexados ao system prompt pelo orquestrador)
# ORION_V2_REFERENCE_LOOKUPS_ENABLED=true
# ORION_V2_REFERENCE_LOOKUPS_MAX_CHARS=48000
# ORION_V2_REFERENCE_LOOKUPS_FILE=/caminho/opcional/reference_lookups.md
