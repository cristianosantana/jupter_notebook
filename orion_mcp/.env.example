# App (usar ORION_ENV; não uses a variável de ambiente genérica `ENV` para o ambiente da app)
ORION_ENV=development
ORION_API_ENABLE_LEGACY_CHAT_ALIAS=false

# PostgreSQL (required in production when ORION_DB_REQUIRED=true)
ORION_DATABASE_URL=postgresql://orion:orion@localhost:5432/orion
# Com `docker compose` deste repo (Postgres cs_postgres, DB `dev`): usar
# postgresql://postgres:secret@localhost:5432/dev no host, ou deixar o compose
# sobrescrever para `@postgres:5432/dev` dentro da rede.
ORION_DB_REQUIRED=false

# Redis (optional; tool cache falls back to in-process if unset)
ORION_REDIS_URL=redis://localhost:6379/0

# Docker Compose (`docker compose up` na raiz de `orion_mcp/`): inclui `docker/docker-compose.yml`.
# O `api` usa `env_file: ../.env` (raiz); o compose sobrescreve ORION_DATABASE_URL,
# ORION_REDIS_URL e ORION_CELERY_BROKER_URL para os hostnames da rede (`postgres`, `redis`).
# Postgres: `docker/postgres/` (Dockerfile + init.sql); dados em `docker/data/`.

# OpenAI (optional for local tests with mocks)
ORION_OPENAI_API_KEY=
# Timeout HTTP do cliente OpenAI (chat stream + embeddings quando há key)
ORION_OPENAI_HTTP_TIMEOUT_SECONDS=60
# Mapa de modelos (Secção 2.6): fast/reasoning para chat; embedding para `embeddings.create`
ORION_LLM_MODEL_FAST=gpt-5-mini
ORION_LLM_MODEL_REASONING=gpt-5
ORION_EMBEDDING_MODEL=text-embedding-3-large
# ≤2000 → índice HNSW (003); >2000 (ex. 3072) → sem índice ANN no pgvector (ver README).
ORION_EMBEDDING_DIMENSIONS=2000
# Reservado se no futuro a 004 voltar a executar SQL IVFFlat
ORION_MEMORY_IVFFLAT_LISTS=100

# Budgets
ORION_MAX_LLM_CALLS_PER_REQUEST=2
ORION_MAX_TOOL_CALLS_PER_REQUEST=1
# Tetos LLM (recomendado): um orçamento de prompt em tokens estimados (~len/4) + opcional teto de caracteres para dados.
# ORION_LLM_PROMPT_TOKEN_BUDGET=6000   # opcional: teto canónico de prompt (tokens estimados); se definido, ignora o min legado abaixo.
# Legado (usados só se ORION_LLM_PROMPT_TOKEN_BUDGET estiver vazio): min(CONTEXT_MAX, LLM_MAX)
ORION_CONTEXT_MAX_TOKENS=3500
ORION_LLM_MAX_PROMPT_TOKENS=3000
# Soma das secções do contexto; o efectivo é min(isto, ORION_LLM_PROMPT_TOKEN_BUDGET ou min legado).
ORION_CONTEXT_SECTION_BUDGET_TOKENS=4000
# Resposta do modelo (chat): independente do teto de contexto. Modelos com raciocínio (ex. gpt-5)
# precisam de margem maior; o default em código é 4096 se não definires aqui.
ORION_LLM_COMPLETION_MAX_TOKENS=4096
# Opcional: teto em caracteres por pedido HTTP (len(system)+len(user)); omitir = sem este corte.
# ORION_LLM_CONTEXT_MAX_CHARS=272000
# Com true, o resumo de consultas catalogadas inclui **todas** as linhas em `rows` (até ao teto de caracteres
# alinhado a ORION_LLM_CONTEXT_MAX_CHARS quando definido). Recomendado definir ambos em conjunto.
# ORION_TOOL_LLM_CATALOG_FULL_ROWS=false
# Chamada insights (JSON): independente do chat.
ORION_LLM_INSIGHTS_MAX_TOKENS=900
# Mensagem system do chat (OpenAI). Sobrescreve o default em código; ver docs/heurística_de_tomada_de_decisão.md e task_profile em ARCHITECTURE.md
ORION_LLM_SYSTEM_PROMPT=""
# Parada antes do LLM: grava pedido em ORION_LLM_DEBUG_LOG_DIR (JSON) e não chama o modelo.
# Variáveis de ambiente do processo sobrepõem o `.env`; reinicia o servidor após alterar.
ORION_LLM_HALT_BEFORE_CHAT=false
# Por defeito (em código): pasta `logs/` na raiz do projecto `orion_mcp/` (no Docker da API: /app/logs).
# No compose oficial, `../logs:/app/logs` expõe esses ficheiros em `orion_mcp/logs/` no host.
ORION_LLM_DEBUG_LOG_DIR=logs
# Logs JSON por linha (logger orion_mcp.orchestration) após prepare + antes do dump de parada LLM
ORION_ORCHESTRATOR_CHAT_TRACE=false
ORION_TOOL_TIMEOUT_SECONDS=10.0

# Long memory (requer extensão pgvector no PostgreSQL; ver README / migrate.py)
ORION_ENABLE_LONG_MEMORY=false
# Enfileirar embed+INSERT após respostas de chat (requer worker Celery + Redis)
ORION_ENABLE_MEMORY_INDEX_WORKER=true

# Celery (embeddings worker)
ORION_CELERY_BROKER_URL=redis://localhost:6379/1

# --- MCP serviço em rede (gRPC) + MySQL só no processo MCP ---
# API / orquestrador: alvo do canal gRPC (obrigatório para execução remota das tools de negócio)
ORION_MCP_GRPC_TARGET=mcp-grpc:50051
ORION_MCP_GRPC_DEADLINE_SECONDS=5
ORION_MCP_GRPC_USE_TLS=false
ORION_MCP_GRPC_RETRY_COUNT=1
ORION_MCP_GRPC_CIRCUIT_FAILURE_THRESHOLD=5
ORION_MCP_GRPC_CIRCUIT_OPEN_SECONDS=30
ORION_MCP_L1_TOOL_CACHE_TTL_SECONDS=300
# Logs de diagnóstico [ORION_MCP] no stdout (API registry/executor)
ORION_MCP_DEBUG_STDOUT=false

# Pré-visualização: API (DataInterpreter) e processo MCP em summarize=true (tamanho de rows_sample). 1–10000.
ORION_TOOL_LLM_PREVIEW_ROWS=10
# Teto de caracteres do bloco catalogado (DataInterpreter). Alias: ORION_LLM_TOOL_CONTEXT_CHARS.
# Se omitido, deriva de ORION_LLM_PROMPT_TOKEN_BUDGET (ou min legado) × 4 × 0.6, limitado a 2000–100000.
# ORION_TOOL_LLM_SUMMARY_MAX_CHARS=48000
ORION_TOOL_DOMAIN_DEFAULT_LIMIT=200
ORION_TOOL_DOMAIN_DEFAULT_SUMMARIZE=true

# Processo `orion-mcp-server` (gRPC): bind, MySQL, Redis L2, concorrência
# ORION_MCP_MYSQL_URL: obrigatório para `run_domain_query` no **container mcp-grpc** (docker-compose
# injeta ../.env nesse serviço). Dentro do Docker, `localhost` no URL aponta para o próprio container.
# Se o MySQL está noutro compose, ou ligas `cs_mysql` à rede Orion (`docker network connect …`) ou
# usas o override `docker/docker-compose.mysql-peer.yml` com ORION_MYSQL_PEER_NETWORK=<rede_do_mysql>.
ORION_MYSQL_PEER_NETWORK=docker-env_cs_backend
ORION_MCP_SERVER_GRPC_HOST=0.0.0.0
ORION_MCP_SERVER_GRPC_PORT=50051
ORION_MCP_MYSQL_URL=mysql://root:secret@localhost:3306/smart
ORION_MCP_MYSQL_POOL_MINSIZE=5
ORION_MCP_MYSQL_POOL_MAXSIZE=20
ORION_MCP_REDIS_URL=redis://localhost:6379/2
ORION_MCP_L2_CACHE_TTL_SECONDS=300
ORION_MCP_QUERY_CONCURRENCY=50

# Gateway HTTP opcional (debug/admin) no mesmo processo que o gRPC
ORION_MCP_HTTP_GATEWAY_ENABLED=false
ORION_MCP_HTTP_GATEWAY_HOST=0.0.0.0
ORION_MCP_HTTP_GATEWAY_PORT=5050
