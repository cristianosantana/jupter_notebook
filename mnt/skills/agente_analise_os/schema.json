{
  "_doc": "Schema das tabelas usadas pelo agente_analise_os. Gerado via DESCRIBE em 2026-03-18.",
  "_relacoes": {
    "os -> os_servicos": "os.id = oss.os_id (1:N, cada OS tem N servicos)",
    "os_servicos -> servicos": "oss.servico_id = ser.id (N:1)",
    "os -> concessionarias": "os.concessionaria_id = con.id (N:1)",
    "os -> funcionarios": "os.vendedor_id = func.id (N:1, vendedor)",
    "os -> caixas": "caixas.os_id = os.id (1:N via EXISTS, sem JOIN)"
  },
  "_regras_negocio": {
    "data_venda": "os.created_at",
    "periodo": "os.created_at >= '2023-01-01'",
    "excluir_cancelados": "os.deleted_at IS NULL (no WHERE SQL)",
    "excluir_valor_zero": "oss_valor_venda_real > 0 (no perguntas_dados)",
    "os_paga": "EXISTS(SELECT 1 FROM caixas cx WHERE cx.os_id = os.id AND cx.cancelado = 0 AND cx.deleted_at IS NULL)",
    "qtd_servicos": "(SELECT COUNT(*) FROM os_servicos oss2 WHERE oss2.os_id = os.id)",
    "granularidade": "1 linha = 1 servico dentro de 1 OS (relacao 1:N)"
  },
  "_prefixos": {
    "os": "sem prefixo (tabela principal)",
    "os_servicos": "oss_",
    "servicos": "ser_ (exceto ser.nome -> servico_nome)",
    "concessionarias": "con_ (exceto con.nome -> concessionaria_nome)",
    "funcionarios": "func_ (exceto func.nome -> vendedor_nome)"
  },
